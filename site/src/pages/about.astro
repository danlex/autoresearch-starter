---
import Layout from '../layouts/Layout.astro';
import { getConfig } from '../lib/config';

const config = getConfig();
const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/');
const metaDesc = `Autoresearch on ${config.subject} — autonomous AI research system by ${config.author.name}. Open source, powered by Claude.`;
---

<Layout title="About" description={metaDesc} activePage="about">
  <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight leading-tight my-6 bg-gradient-to-br from-ar-amber to-ar-red bg-clip-text text-transparent [-webkit-text-fill-color:transparent]">About Autoresearch</h1>

  <div class="glass-card rounded-2xl p-8 my-8">
    <h3 class="text-ar-amber mt-0 mb-1 text-xl font-bold">{config.author.name}</h3>
    {config.author.title && <p class="text-text-secondary m-0 mb-4 font-medium">{config.author.title}, {config.author.company}</p>}
    <p class="text-[#d4d4d8] text-[0.95rem] leading-relaxed">Creator of this Autoresearch instance. Building autonomous AI-powered research tools that produce verified, citation-backed knowledge.</p>
    <p class="mt-3">
      {config.author.github && <a href={`https://github.com/${config.author.github}`} class="text-ar-blue hover:text-ar-cyan no-underline hover:underline mr-6">GitHub</a>}
      <a href={`https://github.com/${config.repo}`} class="text-ar-blue hover:text-ar-cyan no-underline hover:underline">Repository</a>
    </p>
  </div>

  {config.author.logo && (
    <a href={config.author.company_url} target="_blank" rel="noopener" class="glass-card rounded-2xl p-8 my-8 block no-underline">
      <img src={`${base}${config.author.logo}`} alt={config.author.company} class="h-10 mb-4" />
      {config.author.email && <p class="text-dim text-[0.9rem] m-0">{config.author.email}</p>}
    </a>
  )}

  <h2 class="text-2xl font-bold tracking-tight mt-12 mb-4 pb-2 border-b border-border">What is Autoresearch?</h2>
  <p class="text-[#d4d4d8] text-[0.95rem] leading-relaxed">Autoresearch is an autonomous research system. You define a research goal, and the system generates research questions, searches the web, writes findings with inline citations, and verifies everything through a three-judge review panel.</p>

  <h2 class="text-2xl font-bold tracking-tight mt-12 mb-4 pb-2 border-b border-border">How It Works</h2>
  <div class="glass-card rounded-xl p-5 font-mono text-[0.85rem] leading-[2.2] my-4">
    <span class="text-ar-amber">goal.md</span> defines the subject<br>
    &nbsp;&nbsp;&darr;<br>
    <span class="text-ar-cyan">explode-goal.sh</span> generates research tasks<br>
    &nbsp;&nbsp;&darr;<br>
    <span class="text-ar-green">research.sh</span> picks tasks, runs Claude Code (web search + write)<br>
    &nbsp;&nbsp;&darr;<br>
    <span class="text-ar-blue">3 judges</span> review: Evidence, Consistency, Completeness<br>
    &nbsp;&nbsp;&darr;<br>
    <span class="text-ar-green">PR merged</span> &rarr; findings published &rarr; new tasks proposed<br>
    &nbsp;&nbsp;&darr;<br>
    Score climbs toward <span class="text-ar-green">100%</span>
  </div>

  <h2 class="text-2xl font-bold tracking-tight mt-12 mb-4 pb-2 border-b border-border">Source Code</h2>
  <p class="text-[#d4d4d8] text-[0.95rem] leading-relaxed">Autoresearch is open source. The full code, research history, and all Issues are public.</p>
  <p class="my-4">
    <a href={`https://github.com/${config.repo}`} class="inline-block bg-ar-amber text-bg px-5 py-2.5 rounded font-mono font-bold no-underline transition-colors hover:bg-ar-amber/90 text-[0.9rem]">View on GitHub</a>
  </p>
</Layout>
