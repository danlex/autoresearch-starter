---
import Layout from '../layouts/Layout.astro';
import { getConfig } from '../lib/config';

const config = getConfig();
const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/');
const cloneDesc = 'Clone Autoresearch and run autonomous AI research on any subject. One command setup. Verified citations. Published website.';
---

<Layout title="Clone" description={cloneDesc} activePage="clone">
  <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight leading-tight my-6 bg-gradient-to-br from-ar-amber to-ar-red bg-clip-text text-transparent [-webkit-text-fill-color:transparent]">
    Clone Autoresearch
  </h1>

  <p class="text-lg text-text-secondary leading-relaxed my-6">
    Run autonomous AI research on <strong class="text-text-primary">any subject</strong>. One command installs everything, generates research questions, and starts Claude researching with verified citations.
  </p>

  <!-- Big clone button -->
  <div class="glass-card glow-border rounded-2xl p-8 my-8 text-center">
    <p class="font-mono text-[0.85rem] text-dim mb-4">Terminal</p>
    <div class="bg-black/40 rounded-xl p-6 text-left font-mono text-[0.9rem] leading-relaxed">
      <p class="text-dim m-0">$ <span class="text-ar-green">git clone</span> <span class="text-ar-cyan">https://github.com/danlex/autoresearch-starter.git</span> my-research</p>
      <p class="text-dim m-0">$ <span class="text-ar-green">cd</span> my-research</p>
      <p class="text-dim m-0">$ <span class="text-ar-green">bash</span> install.sh</p>
    </div>
    <div class="flex gap-3 justify-center mt-6 flex-wrap">
      <a href="https://github.com/danlex/autoresearch-starter" target="_blank" rel="noopener" class="inline-block bg-ar-amber text-bg px-6 py-3 rounded-xl font-mono font-bold no-underline transition-all hover:bg-ar-amber/90 text-[0.9rem]">
        View on GitHub
      </a>
      <a href="https://github.com/danlex/autoresearch-starter/generate" target="_blank" rel="noopener" class="inline-block bg-white/10 text-text-primary border border-white/15 px-6 py-3 rounded-xl font-mono font-bold no-underline transition-all hover:bg-white/15 text-[0.9rem]">
        Use This Template
      </a>
    </div>
  </div>

  <!-- What you get -->
  <h2 class="text-2xl font-bold tracking-tight mt-12 mb-6 pb-2 border-b border-border">What You Get</h2>
  <div class="grid grid-cols-3 gap-4 my-6 max-md:grid-cols-1">
    <div class="glass-card rounded-2xl p-5 scroll-reveal">
      <div class="text-3xl mb-3">🔍</div>
      <h3 class="text-text-primary font-semibold text-[1rem] mt-0 mb-2">AI Research</h3>
      <p class="text-dim text-[0.85rem] m-0">Claude searches the web, writes findings with inline [N] citations, verifies every claim through three judges.</p>
    </div>
    <div class="glass-card rounded-2xl p-5 scroll-reveal">
      <div class="text-3xl mb-3">🌐</div>
      <h3 class="text-text-primary font-semibold text-[1rem] mt-0 mb-2">Published Website</h3>
      <p class="text-dim text-[0.85rem] m-0">Modern Astro site with WebGL particles, glassmorphism, search, dark/light mode. Auto-deploys to GitHub Pages.</p>
    </div>
    <div class="glass-card rounded-2xl p-5 scroll-reveal">
      <div class="text-3xl mb-3">📊</div>
      <h3 class="text-text-primary font-semibold text-[1rem] mt-0 mb-2">Full Transparency</h3>
      <p class="text-dim text-[0.85rem] m-0">Every task, PR, judge review, and source is public on GitHub. Research score tracks progress to 100%.</p>
    </div>
  </div>

  <!-- How it works -->
  <h2 class="text-2xl font-bold tracking-tight mt-12 mb-6 pb-2 border-b border-border">How It Works</h2>
  <div class="space-y-4 my-6">
    <div class="flex gap-4 items-start scroll-reveal">
      <div class="glass-card rounded-xl w-10 h-10 flex items-center justify-center shrink-0 font-mono font-bold text-ar-amber">1</div>
      <div>
        <h3 class="text-text-primary font-semibold text-[0.95rem] mt-0 mb-1">Define your subject</h3>
        <p class="text-dim text-[0.85rem] m-0">Edit <code class="font-mono bg-white/5 px-1.5 py-0.5 rounded border border-white/10 text-[0.8em]">goal.md</code> — who or what to research, what areas to cover, what "done" looks like.</p>
      </div>
    </div>
    <div class="flex gap-4 items-start scroll-reveal">
      <div class="glass-card rounded-xl w-10 h-10 flex items-center justify-center shrink-0 font-mono font-bold text-ar-cyan">2</div>
      <div>
        <h3 class="text-text-primary font-semibold text-[0.95rem] mt-0 mb-1">Run install</h3>
        <p class="text-dim text-[0.85rem] m-0"><code class="font-mono bg-white/5 px-1.5 py-0.5 rounded border border-white/10 text-[0.8em]">bash install.sh</code> — installs deps, authenticates, generates 30-50 research questions as GitHub Issues.</p>
      </div>
    </div>
    <div class="flex gap-4 items-start scroll-reveal">
      <div class="glass-card rounded-xl w-10 h-10 flex items-center justify-center shrink-0 font-mono font-bold text-ar-green">3</div>
      <div>
        <h3 class="text-text-primary font-semibold text-[0.95rem] mt-0 mb-1">Research runs autonomously</h3>
        <p class="text-dim text-[0.85rem] m-0">Claude Code picks tasks, searches the web, writes findings with citations. Three judges review. PRs auto-merge. Score climbs.</p>
      </div>
    </div>
    <div class="flex gap-4 items-start scroll-reveal">
      <div class="glass-card rounded-xl w-10 h-10 flex items-center justify-center shrink-0 font-mono font-bold text-ar-purple">4</div>
      <div>
        <h3 class="text-text-primary font-semibold text-[0.95rem] mt-0 mb-1">Website publishes automatically</h3>
        <p class="text-dim text-[0.85rem] m-0">After each iteration, the site rebuilds and deploys to GitHub Pages with all findings, sources, and progress.</p>
      </div>
    </div>
  </div>

  <!-- Requirements -->
  <h2 class="text-2xl font-bold tracking-tight mt-12 mb-6 pb-2 border-b border-border">Requirements</h2>

  <div class="space-y-4 my-6">
    <!-- Claude Authentication -->
    <div class="glass-card rounded-2xl p-6">
      <h3 class="text-ar-amber mt-0 mb-3 text-[1rem] font-semibold">Claude Authentication (pick one)</h3>

      <div class="space-y-4">
        <div class="bg-black/20 rounded-xl p-5">
          <h4 class="text-text-primary font-semibold text-[0.9rem] mt-0 mb-2">Option A: OAuth Token (recommended)</h4>
          <p class="text-dim text-[0.85rem] m-0 mb-3">Free with your Claude account. No API billing needed.</p>
          <div class="bg-black/30 rounded-lg p-3 font-mono text-[0.8rem]">
            <p class="text-dim m-0">$ <span class="text-ar-green">npm install -g</span> @anthropic-ai/claude-code</p>
            <p class="text-dim m-0">$ <span class="text-ar-green">claude auth login</span></p>
            <p class="text-dim m-0 mt-1 text-[0.75rem]"># Opens browser → sign in → token saved automatically</p>
            <p class="text-dim m-0 mt-2">$ <span class="text-ar-green">claude auth status</span></p>
            <p class="text-dim m-0 text-[0.75rem]"># Shows: Authenticated as your@email.com</p>
          </div>
          <p class="text-dim text-[0.8rem] mt-3 mb-0">Or set manually in <code class="font-mono bg-white/5 px-1.5 py-0.5 rounded border border-white/10 text-[0.8em]">.env</code>:</p>
          <div class="bg-black/30 rounded-lg p-3 font-mono text-[0.8rem] mt-2">
            <p class="text-dim m-0">CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...</p>
          </div>
        </div>

        <div class="bg-black/20 rounded-xl p-5">
          <h4 class="text-text-primary font-semibold text-[0.9rem] mt-0 mb-2">Option B: API Key</h4>
          <p class="text-dim text-[0.85rem] m-0 mb-3">Pay-per-use. Best for heavy research sessions.</p>
          <ol class="text-dim text-[0.85rem] pl-5 my-0">
            <li class="my-1.5">Go to <a href="https://console.anthropic.com" target="_blank" rel="noopener" class="text-ar-blue hover:text-ar-cyan no-underline hover:underline">console.anthropic.com</a></li>
            <li class="my-1.5">Sign up or log in</li>
            <li class="my-1.5">Go to <strong class="text-text-primary">API Keys</strong> in the left sidebar</li>
            <li class="my-1.5">Click <strong class="text-text-primary">Create Key</strong>, copy it</li>
            <li class="my-1.5">Add to <code class="font-mono bg-white/5 px-1.5 py-0.5 rounded border border-white/10 text-[0.8em]">.env</code>:</li>
          </ol>
          <div class="bg-black/30 rounded-lg p-3 font-mono text-[0.8rem] mt-2">
            <p class="text-dim m-0">ANTHROPIC_API_KEY=sk-ant-api03-...</p>
          </div>
        </div>
      </div>
    </div>

    <!-- GitHub -->
    <div class="glass-card rounded-2xl p-6">
      <h3 class="text-ar-cyan mt-0 mb-3 text-[1rem] font-semibold">GitHub Account</h3>
      <p class="text-dim text-[0.85rem] m-0 mb-3">Required for task management (Issues), code history (PRs), and website hosting (Pages).</p>
      <div class="bg-black/20 rounded-xl p-4">
        <p class="text-dim text-[0.85rem] m-0 mb-2">Install and authenticate the GitHub CLI:</p>
        <div class="bg-black/30 rounded-lg p-3 font-mono text-[0.8rem]">
          <p class="text-dim m-0">$ <span class="text-ar-green">brew install</span> gh &nbsp;&nbsp;&nbsp;<span class="text-dim text-[0.7rem]"># macOS</span></p>
          <p class="text-dim m-0">$ <span class="text-ar-green">gh auth login</span> &nbsp;&nbsp;&nbsp;&nbsp;<span class="text-dim text-[0.7rem]"># opens browser</span></p>
        </div>
      </div>
    </div>

    <!-- System -->
    <div class="glass-card rounded-2xl p-6">
      <h3 class="text-ar-green mt-0 mb-3 text-[1rem] font-semibold">System</h3>
      <p class="text-dim text-[0.85rem] m-0 mb-3">macOS or Linux. The installer handles all dependencies automatically:</p>
      <div class="grid grid-cols-2 gap-3 max-md:grid-cols-1">
        <div class="bg-black/20 rounded-xl p-4">
          <p class="text-text-primary font-semibold text-[0.85rem] m-0 mb-1">Auto-installed</p>
          <ul class="text-dim text-[0.8rem] pl-4 my-0">
            <li>Node.js 22+</li>
            <li>GitHub CLI (gh)</li>
            <li>Claude Code CLI</li>
            <li>jq (JSON processor)</li>
          </ul>
        </div>
        <div class="bg-black/20 rounded-xl p-4">
          <p class="text-text-primary font-semibold text-[0.85rem] m-0 mb-1">Optional</p>
          <ul class="text-dim text-[0.8rem] pl-4 my-0">
            <li>ShellCheck (linting)</li>
            <li>VS Code (editing)</li>
            <li>Custom domain (SEO)</li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Example subjects -->
  <h2 class="text-2xl font-bold tracking-tight mt-12 mb-6 pb-2 border-b border-border">Research Any Subject</h2>
  <p class="text-text-secondary text-[0.95rem] mb-6">Autoresearch works for people, companies, technologies, events — anything with public information.</p>
  <div class="grid grid-cols-2 gap-3 my-6 max-md:grid-cols-1">
    {[
      { name: 'Albert Einstein', desc: 'Physics, relativity, Nobel Prize' },
      { name: 'SpaceX', desc: 'Rockets, Starship, Mars mission' },
      { name: 'Bitcoin', desc: 'Cryptocurrency, blockchain, Satoshi' },
      { name: 'Marie Curie', desc: 'Radioactivity, Nobel Prizes, legacy' },
      { name: 'CRISPR', desc: 'Gene editing, Doudna, applications' },
      { name: 'OpenAI', desc: 'GPT, AGI, Sam Altman, safety' },
    ].map(ex => (
      <div class="glass-card rounded-xl p-4">
        <strong class="text-ar-amber text-[0.9rem]">{ex.name}</strong>
        <p class="text-dim text-[0.8rem] mt-1 mb-0">{ex.desc}</p>
      </div>
    ))}
  </div>

  <!-- CTA -->
  <div class="glass-card glow-border rounded-2xl p-8 my-12 text-center">
    <h2 class="text-2xl font-bold tracking-tight mt-0 mb-3">Start in 60 seconds</h2>
    <p class="text-text-secondary text-[0.95rem] mb-6 max-w-lg mx-auto">Clone the repo, edit your subject, run one command. Research starts automatically.</p>
    <a href="https://github.com/danlex/autoresearch-starter" target="_blank" rel="noopener" class="inline-block bg-ar-amber text-bg px-8 py-3.5 rounded-xl font-mono font-bold no-underline transition-all hover:bg-ar-amber/90 text-[1rem]">
      Clone Autoresearch
    </a>
  </div>
</Layout>
