# Autoresearch Configuration
# Copy to .env and fill in your values

# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-...

# Research settings
MAX_ITERATIONS=100           # Max iterations per session (default: 100)
RESEARCH_MODEL=claude-opus-4-5  # Model for research tasks
HARD_RESEARCH_MODEL=claude-opus-4-5  # Model for hard/failed tasks
NO_JUDGES=1                  # 1 = auto-merge (fast), 0 = three-judge review
AUTO_ACCEPT=high             # Auto-accept proposed tasks: 0, high, medium, low, all
